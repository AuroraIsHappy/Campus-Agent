# Campus-Agent configuration (.env.example)
# Copy to .env and fill in your keys. All keys are OPTIONAL — the app runs in
# offline/deterministic mode without any of them. Add keys to enable real features.

# ---- Core ----
# Where Campus stores runs, tasks, memory, artifacts (default: ~/.campus)
# CAMPUS_HOME=~/.campus
# Disable the background scheduler (daily reminders, auto-learn, memory compress)
# CAMPUS_DISABLE_SCHEDULER=1
# CORS origins for production (comma-separated, default: localhost)
# CAMPUS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Environment: "prod" disables /docs (Swagger), "dev" keeps it
# CAMPUS_ENV=dev

# ---- LLM (required for real AI generation) ----
# At least one provider key. GLM (Zhipu) is the default + recommended.
# Configure in ~/.hermes/.env (Hermes loads this), OR set here:
GLM_API_KEY=
GLM_BASE_URL=
# Alternatives:
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ---- Notion (optional — research note sync) ----
# Create a Notion integration at https://www.notion.so/my-integrations
# Then create a database and copy its ID from the URL
NOTION_INTEGRATION_TOKEN=
NOTION_DATABASE_ID=
# (legacy names also accepted: NOTION_TOKEN, NOTION_RESEARCH_DATABASE_ID)

# ---- Zotero (optional — literature management, Phase 9) ----
# Get your user ID + API key at https://www.zotero.org/settings/keys
ZOTERO_USER_ID=
ZOTERO_API_KEY=

# ---- GitHub (optional — real trending repos) ----
# Personal access token from https://github.com/settings/tokens
GITHUB_TOKEN=

# ---- Web Search (optional — research paper search) ----
# Get a key at https://tavily.com
TAVILY_API_KEY=

# ---- Mobile Push (optional — Feishu / QQ Bot) ----
# Feishu: set up a bot at https://open.feishu.cn, then:
CAMPUS_FEISHU_CHAT_ID=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_DOMAIN=
# Feishu Calendar (optional — sync study/review plans to your calendar)
# The calendar ID from the Feishu calendar you want events written to.
FEISHU_CALENDAR_ID=
# QQ Bot: set up at https://q.qq.com, then:
QQ_APP_ID=
QQ_CLIENT_SECRET=
QQBOT_HOME_CHANNEL=
# ---- Scheduled Quiz Push (optional — Phase 9) ----
# Which channel to push daily quizzes to: feishu | qq
# CAMPUS_QUIZ_PUSH_CHANNEL=feishu
# Time of day (HH:MM, 24h) to push the daily quiz (default 09:00)
# CAMPUS_QUIZ_PUSH_TIME=09:00

# ---- Hermes Agent (the LLM runtime — installed automatically) ----
# Hermes is NOT on PyPI. It's installed from the GitHub clone during Docker build.
# For local (non-Docker) setup, run:
#   git clone https://github.com/NousResearch/hermes-agent.git ../hermes-agent
#   cd ../hermes-agent && pip install -e .
# Or use the official installer: https://hermes-agent.nousresearch.com/install.sh
